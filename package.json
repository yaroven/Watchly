{
  "name": "watchly",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "commitlint": "commitlint",
    "docker:dev": "docker compose --project-name watchly -f ./config/dev/docker-compose.yml",
    "dev:up": "pnpm docker:dev up -d",
    "dev:down": "pnpm docker:dev down",
    "lint:api": "pnpm --filter api precommit",
    "lint:client": "pnpm --filter client precommit",
    "lint": "pnpm lint:api && pnpm lint:client",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  }
}
