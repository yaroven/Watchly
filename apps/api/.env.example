NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://root:root@localhost:5432/watchly?schema=public"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# S3 / LocalStack
S3_ACCESS_KEY_ID=localstack
S3_SECRET_ACCESS_KEY=localstack
S3_REGION=us-east-1
S3_RAW_BUCKET_NAME=raw
S3_PROCESSED_BUCKET_NAME=content
S3_ENDPOINT_INTERNAL=http://localhost:4566
S3_ENDPOINT_PUBLIC=http://localhost:4566

# SQS (S3 event notifications)
SQS_QUEUE_NAME=s3-event-queue
