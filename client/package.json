{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "commitlint": "commitlint",
    "dev": "next dev --hostname 0.0.0.0 -p 4000",
    "build": "next build",
    "prepare": "husky",
    "start": "next start -p 4000",
    "prettier:write": "prettier --write --ignore-unknown",
    "prettier:check": "prettier --check --ignore-unknown",
